rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /breweries/{breweryId} {
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.auth.uid in request.resource.data.members;

      allow read: if request.auth != null && (request.auth.uid == resource.data.ownerId || request.auth.uid in resource.data.members || request.auth.token.email in resource.data.invitedEmails);
      
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.ownerId || request.auth.uid in resource.data.members) ||
        (
          request.auth.token.email in resource.data.invitedEmails &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'invitedEmails']) &&
          request.resource.data.members.size() == resource.data.members.size() + 1 &&
          request.auth.uid in request.resource.data.members &&
          !(request.auth.token.email in request.resource.data.invitedEmails)
        )
      );

      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
      
      match /inventory/{itemId} {
        allow read: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/breweries/$(breweryId)).data.ownerId || request.auth.uid in get(/databases/$(database)/documents/breweries/$(breweryId)).data.members);
        allow write: if request.auth != null
                     && (request.auth.uid == get(/databases/$(database)/documents/breweries/$(breweryId)).data.ownerId || request.auth.uid in get(/databases/$(database)/documents/breweries/$(breweryId)).data.members)
                     && request.resource.data.breweryId == breweryId;
      }
    }
    match /ingredients/{ingredientId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false; 
    }
    match /recipes/{recipeId} {
      allow create: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/breweries/$(request.resource.data.breweryId)).data.ownerId || request.auth.uid in get(/databases/$(database)/documents/breweries/$(request.resource.data.breweryId)).data.members);
      allow read, update, delete: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/breweries/$(resource.data.breweryId)).data.ownerId || request.auth.uid in get(/databases/$(database)/documents/breweries/$(resource.data.breweryId)).data.members);
    }
    match /brew_sessions/{sessionId} {
      allow create: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/breweries/$(request.resource.data.breweryId)).data.ownerId || request.auth.uid in get(/databases/$(database)/documents/breweries/$(request.resource.data.breweryId)).data.members);
      allow read, update, delete: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/breweries/$(resource.data.breweryId)).data.ownerId || request.auth.uid in get(/databases/$(database)/documents/breweries/$(resource.data.breweryId)).data.members);
    }
  }
}