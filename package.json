{
  "name": "mead-brew-tracker-pwa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:functions": "npm --prefix ai-backend run build",
    "preview": "vite preview",
    "i18n:extract": "npx i18next-parser --config i18next-parser.config.cjs \"src/**/*.{ts,tsx}\"",
    "i18n:translate": "npx tsx --env-file=.env scripts/auto-translate.ts",
    "i18n:upload": "npx tsx --env-file=.env scripts/uploadTranslations.ts",
    "i18n:sync": "npm run i18n:extract && npm run i18n:translate && npm run i18n:upload",
    "lint:css": "stylelint \"src/**/*.css\" \"src/**/*.scss\" --quiet",
    "lint:css:fix": "stylelint \"src/**/*.css\" \"src/**/*.scss\" --fix --quiet",
    "lint:js": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --quiet",
    "lint:js:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --quiet",
    "lint:types": "tsc -b --noEmit",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:types",
    "fix": "npm run lint:js:fix && npm run lint:css:fix",
    "db:seed": "npx tsx scripts/clearIngredients.ts",
    "deploy:prod": "npm run build && firebase deploy",
    "deploy:all": "npm run deploy:prod"
  },
  "dependencies": {
    "@genkit-ai/googleai": "^1.28.0",
    "date-fns": "^4.4.0",
    "firebase": "^12.14.0",
    "genkit": "^1.36.0",
    "i18next": "^25.7.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "firebase-admin": "^13.1.0",
    "globals": "^17.6.0",
    "i18next-parser": "^9.4.0",
    "sass": "^1.100.0",
    "stylelint": "^16.2.0",
    "stylelint-config-recess-order": "^5.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.24.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  }
}
